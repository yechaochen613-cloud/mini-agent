# 智谱（Zhipu / BigModel）OpenAI 兼容配置
# 把本文件复制为 .env 并填入你的 Key 即可

# 在 https://open.bigmodel.cn 控制台 -> 接口 API Key 获取
OPENAI_API_KEY=你的智谱Key

# 智谱的 OpenAI 兼容地址（结尾要带 /）
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# 模型选择（都支持工具调用 / function calling）：
#   glm-4-flash  -> 免费，适合学习和测试（默认）
#   glm-4-air   -> 便宜、快
#   glm-4-plus  -> 最强，复杂任务更稳
OPENAI_MODEL=glm-4-flash

# 关掉离线模式，接真实大模型
MOCK=false

# ===== 长期记忆的嵌入后端（真·RAG） =====
# 可选值：zhipu（默认，用智谱 embedding-3）| openai（任意 OpenAI 兼容嵌入端点）| keyword（本地关键词兜底，无需联网）
# 注意：智谱的嵌入模型需要单独购买「embeddings 资源包」，否则会 429 降级到 keyword 模式。
EMBEDDING_PROVIDER=zhipu
EMBEDDING_MODEL=embedding-3

# 如果用 openai 兼容的嵌入端点（如你另有 OpenAI Key），填下面三项，并把上面改成 openai：
# EMBEDDING_BASE_URL=https://api.openai.com/v1/
# EMBEDDING_API_KEY=sk-xxx
# EMBEDDING_MODEL_OPENAI=text-embedding-3-small
