# 密钥：千万别提交！
.env

# Python 缓存
__pycache__/
*.pyc
*.pyo

# 运行时数据（持久化到 data/ 或挂载盘，不入库）
data/
*.db
*.db-wal
*.db-shm
notes.json
memory.json
documents.json
conversations.json
uploads/

# 本地虚拟环境
venv/
.venv/

# 本地部署钩子（不进仓库）
.deploy_hook

# 部署辅助文件（本地/其他平台用，不入主仓库）
deploy/
run_server.sh

# 前端依赖与构建缓存（dist/ 构建产物需提交，node_modules 不提交）
node_modules/
frontend/node_modules/
frontend/dist/.vite/
*.local
